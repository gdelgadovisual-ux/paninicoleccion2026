rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: orders
    // Document ID: auto-generated
    // Fields:
    //   - nombre: string (required)
    //   - cedula: string (required)
    //   - celular: string (required)
    //   - correo: string (required)
    //   - cuotas: number
    //   - archivoUrl: string
    //   - entregaTipo: string (sede/domicilio)
    //   - sede: string
    //   - ciudad: string
    //   - direccion: string
    //   - barrio: string
    //   - localidad: string
    //   - productos: list (required)
    //   - subtotal: number
    //   - costoEnvio: number
    //   - total: number (required)
    //   - createdAt: timestamp (required)
    //   - uid: string (required)
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidOrder(data) {
      return data.nombre is string && data.nombre.size() > 0 && data.nombre.size() < 200 &&
             data.cedula is string && data.cedula.size() > 0 &&
             data.celular is string &&
             data.correo is string &&
             data.productos is list &&
             data.total is number && data.total >= 0 &&
             (data.uid == null || data.uid is string) &&
             data.createdAt is timestamp;
    }

    match /orders/{orderId} {
      // Solo el dueño puede leer sus pedidos (si estaba autenticado)
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      
      // Permitir creación pública
      allow create: if isValidOrder(request.resource.data);
      
      // No se permiten actualizaciones ni eliminaciones por ahora para integridad de datos
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
